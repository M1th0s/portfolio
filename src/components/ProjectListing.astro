---
import type { CollectionEntry } from 'astro:content';

interface Props {
    project: CollectionEntry<'projects'>;
}

const { project }: Props = Astro.props;

const { title, mainImage, client, work } = project.data;
---

<article class="project">
    <a class="project__link" href={`/projects/${project.id}`} aria-label={title}>
        <div class="project__image">
            <img src={mainImage.src} alt={title} />
        </div>

        <div class="project__info">
            <h3 class="project__title">{title}</h3>

            {client && <span class="project__tag">{client}</span>}
            {work && <span class="project__tag">{work}</span>}
        </div>
    </a>
</article>

<style>
    .project {
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        overflow: hidden;
        transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                    box-shadow 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .project:hover {
        transform: translateY(-8px);
        box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5);
    }

    .project__link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .project__image {
        aspect-ratio: 3 / 2;
        overflow: hidden;
    }

    .project__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.4s ease;
    }

    .project:hover .project__image img {
        transform: scale(1.06);
    }

    .project__info {
        padding: 1.25rem 1.25rem 1.5rem;
    }

    .project__title {
        color: var(--secondary-color-100);
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 0.85rem;
        transition: color 0.3s ease;
    }

    .project:hover .project__title {
        color: var(--primary-color-400);
    }

    .project__tag {
        display: inline-block;
        font-size: 0.78rem;
        padding: 0.25rem 0.85rem;
        border-radius: 2rem;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.07);
        color: var(--secondary-color-200);
        margin-right: 0.5rem;
        margin-bottom: 0.25rem;
    }
</style>
